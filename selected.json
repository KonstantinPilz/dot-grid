[{"name":"Tidal","n":13,"steps":6,"code":"(x,y,n,s)=>{ const u=x/(n-1), v=y/(n-1); const f=(Math.sin(u*Math.PI*2 - v*1.5)+1)/2; return Math.max(0,Math.min(s,Math.round(f*s))); }"},{"name":"Deep Current","n":13,"steps":6,"code":"(x,y,n,s)=>{ const u=x/(n-1), v=y/(n-1); const f=(Math.sin((u+0.3*Math.sin(v*Math.PI*2))*Math.PI*4)+1)/2; return Math.max(0,Math.min(s,Math.round(f*s))); }"},{"name":"Corner Wake","n":13,"steps":6,"code":"(x,y,n,s)=>{ const r=Math.hypot(x,y); const f=(Math.sin(r*1.5)+1)/2; return Math.max(0,Math.min(s,Math.round(f*s))); }"},{"name":"Chevron Sea","n":13,"steps":6,"code":"(x,y,n,s)=>{ const cx=(n-1)/2; const d=Math.abs(x-cx)+y; const f=(Math.sin(d*0.9)+1)/2; return Math.max(0,Math.min(s,Math.round(f*s))); }"},{"name":"Maelstrom","n":13,"steps":6,"code":"(x,y,n,s)=>{ const cx=(n-1)/2, cy=(n-1)/2; const a=Math.atan2(y-cy,x-cx); const r=Math.hypot(x-cx,y-cy); const f=(Math.sin(a*2 - r*1.5)+1)/2; return Math.max(0,Math.min(s,Math.round(f*s))); }"},{"name":"Solitary","n":13,"steps":6,"code":"(x,y,n,s)=>{const cx=n*0.48,cy=n*0.52,sig=n*0.27;const d2=(x-cx)**2+(y-cy)**2;const v=s*Math.exp(-d2/(2*sig*sig));return Math.max(0,Math.min(s,Math.round(v)));}"},{"name":"Twin Fusion","n":13,"steps":6,"code":"(x,y,n,s)=>{const B=[[0.38,0.5,0.2],[0.62,0.5,0.2]];let f=0;for(const[fx,fy,fr]of B){const bx=fx*n,by=fy*n,r=fr*n;const d=Math.hypot(x-bx,y-by);f+=r*r/(d*d+0.7);}return Math.max(0,Math.min(s,Math.round(f*1.7)));}"},{"name":"Halo","n":13,"steps":6,"code":"(x,y,n,s)=>{const cx=n*0.5,cy=n*0.5;const d=Math.hypot(x-cx,y-cy);const ring=Math.exp(-((d-n*0.3)**2)/(2*(n*0.12)**2));return Math.max(0,Math.min(s,Math.round(ring*s)));}"},{"name":"Soft Crescent","n":13,"steps":6,"code":"(x,y,n,s)=>{const c1x=n*0.45,c1y=n*0.5,c2x=n*0.62,c2y=n*0.45;const sig=n*0.3;const a=Math.exp(-((x-c1x)**2+(y-c1y)**2)/(2*sig*sig));const b=0.85*Math.exp(-((x-c2x)**2+(y-c2y)**2)/(2*(n*0.22)**2));return Math.max(0,Math.min(s,Math.round((a-b+0.15)*s*1.3)));}"},{"name":"Plume","n":13,"steps":6,"code":"(x,y,n,s)=>{const bx=n*0.5;const sig=n*(0.16+0.012*y);const v=s*Math.exp(-((x-bx)**2)/(2*sig*sig))*Math.exp(-Math.abs(y-n*0.55)/(n*0.6));return Math.max(0,Math.min(s,Math.round(v*1.4)));}"},{"name":"Loose Galaxy","n":15,"steps":6,"code":"(x,y,n,s)=>{const cx=(n-1)/2,cy=(n-1)/2,dx=x-cx,dy=y-cy,r=Math.hypot(dx,dy)+1e-6,a=Math.atan2(dy,dx);const f=(Math.sin(a*2+Math.log(r+1)*4)+1)/2,env=Math.exp(-r/(n*0.5));const v=f*env*s;return Math.max(0,Math.min(s,Math.round(v)));}"},{"name":"Whirlpool","n":15,"steps":6,"code":"(x,y,n,s)=>{const cx=(n-1)/2,cy=(n-1)/2,dx=x-cx,dy=y-cy,r=Math.hypot(dx,dy)+1e-6,a=Math.atan2(dy,dx);const f=(Math.sin(a*1+r*r*0.06)+1)/2,env=Math.exp(-r/(n*0.6));const v=f*env*s;return Math.max(0,Math.min(s,Math.round(v)));}"},{"name":"Quad Swirl","n":13,"steps":6,"code":"(x,y,n,s)=>{const cx=(n-1)/2,cy=(n-1)/2,dx=x-cx,dy=y-cy,r=Math.hypot(dx,dy)+1e-6,a=Math.atan2(dy,dx);const f=(Math.sin(a*4+r*1.3)+1)/2,env=1-Math.abs(r-n*0.3)/(n*0.4);const v=f*Math.max(0,env)*s;return Math.max(0,Math.min(s,Math.round(v)));}"},{"name":"Diagonal Ramp","n":13,"steps":6,"code":"(x,y,n,s)=>{const u=x/(n-1),v=y/(n-1);return Math.max(0,Math.min(s,Math.round((u+v)/2*s)));}"},{"name":"Dome","n":13,"steps":6,"code":"(x,y,n,s)=>{const u=x/(n-1)-0.5,v=y/(n-1)-0.5;let d=Math.sqrt(u*u+v*v)/0.707;return Math.max(0,Math.min(s,Math.round((1-d)*s)));}"},{"name":"Drape","n":13,"steps":6,"code":"(x,y,n,s)=>{const u=x/(n-1),v=y/(n-1);let f=(Math.sin((u+v)*Math.PI*2.5)+1)/2;return Math.max(0,Math.min(s,Math.round(f*s)));}"},{"name":"Cresting Dunes","n":13,"steps":6,"code":"(x,y,n,s)=>{const u=x/(n-1),v=y/(n-1);let f=(Math.sin((u+v*0.5)*Math.PI*2.2)+1)/2;return Math.max(0,Math.min(s,Math.round(f*s)));}"},{"name":"Flowing Warp","n":13,"steps":6,"code":"(x,y,n,s)=>{const u=x/(n-1),v=y/(n-1);let f=(u+v)/2+0.18*Math.sin(v*Math.PI*3);return Math.max(0,Math.min(s,Math.round(f*s)));}"},{"name":"Marble Veins","n":13,"steps":6,"code":"(x,y,n,s)=>{const wx=x+3*Math.sin(y*0.45);const v=Math.abs(Math.sin(wx*0.5+y*0.2));return Math.max(0,Math.min(s,Math.round((1-v)*s)));}"},{"name":"Drifting Smoke","n":15,"steps":6,"code":"(x,y,n,s)=>{const wy=y+2.5*Math.sin(x*0.35);const f=Math.sin(x*0.4+wy*0.3)+0.5*Math.cos(wy*0.6+1)+0.3*Math.sin(x*0.9+2);return Math.max(0,Math.min(s,Math.round((f/1.8/2+0.5)*s)));}"}]