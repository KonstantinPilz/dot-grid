    "steps": 6,
    "code": "(x,y,n,s)=>{const B=[[0.32,0.42,0.16],[0.6,0.55,0.18],[0.5,0.3,0.12]];let f=0;for(const[fx,fy,fr]of B){const bx=fx*n,by=fy*n,r=fr*n;const d=Math.hypot(x-bx,y-by);f+=r*r/(d*d+0.6);}return Math.max(0,Math.min(s,Math.round(f*2.0)));}"
