[
  {
    "name": "Diagonal Ramp",
    "n": 13,
    "steps": 6,
    "code": "(x,y,n,s)=>{const u=x/(n-1),v=y/(n-1);return Math.max(0,Math.min(s,Math.round((u+v)/2*s)));}"
  },
